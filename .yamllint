---
extends: default

ignore: |
  .git/

rules:
  document-start: disable
  line-length:
    max: 140
  comments:
    min-spaces-from-content: 1
  comments-indentation: false
  braces:
    max-spaces-inside: 1
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
  truthy:
    allowed-values: ['true', 'false']
    check-keys: false
